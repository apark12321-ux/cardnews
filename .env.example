# Server
PORT=3000
GRAPH_API_VERSION=v23.0

# Instagram Graph API
# Instagram Business/Creator account ID connected to a Facebook Page.
IG_USER_ID=
INSTAGRAM_ACCESS_TOKEN=

# Instagram publishing behavior
# Default 10 for conservative compatibility. Set to 20 only after confirming your API/app supports it.
MAX_CAROUSEL_IMAGES=10
IG_WAIT_FOR_READY=true
IG_READY_MAX_ATTEMPTS=12
IG_READY_INTERVAL_MS=5000

# Cloudinary image hosting
# Instagram Graph API needs public HTTPS image URLs for carousel publishing.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=yojeumdon-cardnews

# Optional: set to true to block live publish and allow dry-run only.
DRY_RUN_ONLY=false
